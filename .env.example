# Copy to .env and replace every change-me value before exposing the MCP server.

# Backend data/API
PROFILE_OS_BACKEND_PORT=8000
PROFILE_OS_MCP_PORT=8080
PROFILE_OS_MCP_BACKEND_PROFILES=*

# Secret used only by the MCP server when it calls the Profile OS backend.
# Never paste this into Claude or a browser.
PROFILE_OS_MCP_BACKEND_BEARER=change-me-long-random-backend-secret

# Public HTTPS origin for the MCP service, including scheme and no trailing slash.
# Set this to the tunnel/deploy URL before using OAuth so issued tokens get the
# correct audience, for example: https://profile-os.example.com
MCP_PUBLIC_BASE_URL=https://change-me.example.com

# Claude-facing MCP auth. Use OAuth when Claude discovers the metadata; keep a
# static connector token only if the connector UI asks for bearer-token auth.
MCP_AUTH_REQUIRED=1
MCP_CONNECTOR_TOKEN=change-me-long-random-connector-token
MCP_CONNECTOR_TOKENS=
MCP_OAUTH_SIGNING_KEY=change-me-long-random-oauth-signing-key

# Origin and OAuth redirect allowlists for Claude.ai custom connectors.
MCP_ALLOWED_ORIGINS=https://claude.ai,https://*.claude.ai
MCP_OAUTH_ALLOWED_REDIRECT_HOSTS=claude.ai,*.claude.ai
